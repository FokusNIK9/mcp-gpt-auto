{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "status": { "enum": ["approved", "needs_changes", "rejected"] },
    "summary": { "type": "string" },
    "diffReviewed": { "type": "boolean" },
    "tests": {
      "type": "object",
      "properties": {
        "build": { "enum": ["passed", "failed", "skipped"] }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "message": { "type": "string" }
        }
      }
    },
    "decision": { "enum": ["commit", "request_subagent_fix", "ask_user"] }
  },
  "required": ["status", "summary", "decision"]
}
